<?xml version="1.0" encoding="utf-8"?>
<!--
    Full app logo (background + mark) for in-app use, e.g. the Home hero.
    A rounded-square indigo->violet gradient with the white download mark.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Rounded-square background with brand gradient -->
    <path android:pathData="M24,4 h60 a20,20 0 0 1 20,20 v60 a20,20 0 0 1 -20,20 h-60 a20,20 0 0 1 -20,-20 v-60 a20,20 0 0 1 20,-20 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="4"
                android:startY="4"
                android:endX="104"
                android:endY="104">
                <item android:offset="0" android:color="#FF6D28D9" />
                <item android:offset="1" android:color="#FF4338CA" />
            </gradient>
        </aapt:attr>
    </path>
    <!-- White download mark -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M49,30 h10 v18 h11 l-16,20 l-16,-20 h11 z" />
    <path
        android:fillColor="#00000000"
        android:strokeColor="#FFFFFFFF"
        android:strokeWidth="7"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M34,74 v4 a5,5 0 0 0 5,5 h30 a5,5 0 0 0 5,-5 v-4" />
</vector>

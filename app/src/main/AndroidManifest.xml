<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Core networking: fetch pages, playlists, segments, keys -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Foreground service so long downloads survive the app being backgrounded.
        The DATA_SYNC type is justified: we actively transfer/convert user-requested
        media while the notification is shown. tools:ignore silences the lint hint that
        asks for this justification, which is documented here.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:ignore="ForegroundServicePermission,ForegroundServiceType" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notifications (runtime permission on Android 13+) for download progress -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        NOTE on storage: we target API 29+ and write the finished MP4 straight into
        the MediaStore Movies collection, so no WRITE_EXTERNAL_STORAGE is required.
    -->

    <application
        android:name=".VideoDownloaderApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:hardwareAccelerated="true"
        android:theme="@style/Theme.Videodownloader"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Videodownloader"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            WorkManager's foreground service is declared by the library WITHOUT a
            foregroundServiceType. Because DownloadWorker calls setForeground() with the
            DATA_SYNC type, Android 12+/14 requires that type to also be declared on the
            service element (the runtime type must be a subset of the manifest type), or
            startForeground throws IllegalArgumentException and crashes the process.
            We merge the attribute onto WorkManager's service here.
        -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!--
            Disable WorkManager's default initializer: we provide our own WorkerFactory
            (DownloadWorkerFactory) via Configuration.Provider in VideoDownloaderApp so the
            worker gets its constructor dependencies from the manual-DI container.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
